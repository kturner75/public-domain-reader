# Local-only overrides for Spring Boot local-dev profile.
# Copy to .env.local. This file is gitignored by the existing .env.* rule.

# Google reader-account auth
ACCOUNT_AUTH_GOOGLE_ENABLED=true
ACCOUNT_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
ACCOUNT_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
ACCOUNT_AUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/account/google/callback

# Optional local DB overrides
# PDR_DATABASE_URL=jdbc:postgresql://localhost:5432/classic_chat_reader
# PDR_DATABASE_USERNAME=
# PDR_DATABASE_PASSWORD=
